# AWS DynamoDB Configuration
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local
DYNAMODB_ENDPOINT_URL=http://localhost:8000

# JWT Configuration
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=16

# Application
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8080
